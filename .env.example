# Copy this file to .env and fill in your own values.
# Both VITE_ prefixed vars are exposed to the client bundle.

# Supabase — create a project at https://app.supabase.com, then
# Project Settings → API → copy the URL and the "anon public" key.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# LLM recommender — optional. Leave VITE_OPENAI_API_KEY blank to use the
# built-in rule-based recommender. When set, lib/recommendations.ts
# pre-filters the catalogue with the rule-based scorer and asks the model
# to rank + explain the top picks.
#
# Works with any OpenAI-compatible Chat Completions endpoint:
#   - OpenAI      (default)    VITE_OPENAI_BASE_URL=https://api.openai.com/v1
#                              VITE_OPENAI_MODEL=gpt-4o-mini
#   - OpenRouter               VITE_OPENAI_BASE_URL=https://openrouter.ai/api/v1
#                              VITE_OPENAI_MODEL=openai/gpt-4o-mini
#
# WARNING: VITE_* vars are bundled into the browser JS. For production,
# move this to a backend proxy and strip the client-side key.
VITE_OPENAI_API_KEY=
VITE_OPENAI_BASE_URL=
VITE_OPENAI_MODEL=
